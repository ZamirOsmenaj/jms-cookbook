<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [CONSUMER] %-5level %-35logger{35} - %msg%n</pattern>
        </encoder>
    </appender>
    <logger name="org.apache.activemq" level="WARN"/>
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>

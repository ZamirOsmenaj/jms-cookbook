<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%-20thread] %-5level %-40logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="org.apache.activemq" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
